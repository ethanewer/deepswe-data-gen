--- /dev/null
+++ b/nemo_automodel/components/models/qwen3_vl_text/state_dict_adapter.py
@@ -0,0 +1,46 @@
+"""State-dict adapter for training the text tower from Qwen3-VL checkpoints."""
+
+from __future__ import annotations
+
+import re
+from typing import Any
+
+from nemo_automodel.components.checkpoint.state_dict_adapter import StateDictAdapter
+
+
+class Qwen3VLTextStateDictAdapter(StateDictAdapter):
+    """Map text-only module keys to the language-model keys in Qwen3-VL checkpoints."""
+
+    _native_prefix = "model."
+    _hf_prefix = "model.language_model."
+
+    def _to_hf_key(self, key: str) -> str:
+        if key.startswith(self._native_prefix):
+            return f"{self._hf_prefix}{key[len(self._native_prefix):]}"
+        return key
+
+    def _from_hf_key(self, key: str) -> str | None:
+        if key.startswith(self._hf_prefix):
+            return f"{self._native_prefix}{key[len(self._hf_prefix):]}"
+        if key.startswith("lm_head."):
+            return key
+        return None
+
+    def to_hf(self, state_dict: dict[str, Any], exclude_key_regex: str | None = None, **kwargs) -> dict[str, Any]:
+        out: dict[str, Any] = {}
+        for key, value in state_dict.items():
+            if exclude_key_regex is not None and re.search(exclude_key_regex, key):
+                continue
+            out[self._to_hf_key(key)] = value
+        return out
+
+    def from_hf(self, hf_state_dict: dict[str, Any], **kwargs) -> dict[str, Any]:
+        out: dict[str, Any] = {}
+        for key, value in hf_state_dict.items():
+            mapped = self._from_hf_key(key)
+            if mapped is not None:
+                out[mapped] = value
+        return out
+
+    def convert_single_tensor_to_hf(self, fqn: str, tensor: Any, **kwargs) -> list[tuple[str, Any]]:
+        return [(self._to_hf_key(fqn), tensor)]
