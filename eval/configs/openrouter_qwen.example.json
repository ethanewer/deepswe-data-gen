{
  "model": {
    "name": "qwen/qwen3.5-9b",
    "api_base": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "temperature": 0,
    "max_tokens": 4096,
    "extra_body": {
      "provider": {
        "order": ["venice/fp8", "together", "siliconflow/fp8"],
        "allow_fallbacks": true
      }
    }
  },
  "benchmarks": {
    "deepswe": {
      "enabled": true,
      "limit": 5,
      "n_attempts": 1,
      "n_concurrent": 5
    },
    "swebench_multilingual": {
      "enabled": true,
      "generation_workers": 8,
      "eval_workers": 4
    },
    "livecodebench_v6": {
      "enabled": true,
      "all_tasks": false,
      "n": 3,
      "generation_workers": 525,
      "eval_workers": 64,
      "timeout": 6
    }
  }
}
