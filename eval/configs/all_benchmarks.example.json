{
  "model": {
    "name": "deepseek-v4-flash",
    "api_base": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0,
    "max_tokens": 4096,
    "extra_body": {
      "thinking": {
        "type": "disabled"
      }
    }
  },
  "benchmarks": {
    "deepswe": {
      "enabled": true,
      "limit": 5,
      "n_attempts": 1,
      "n_concurrent": 5
    },
    "swebench_multilingual": {
      "enabled": true,
      "harness": "mini-swe-agent",
      "openhands_command_cwd": null,
      "generation_workers": 8,
      "eval_workers": 4
    },
    "livecodebench_v6": {
      "enabled": true,
      "all_tasks": false,
      "n": 3,
      "generation_workers": 525,
      "eval_workers": 64,
      "timeout": 6
    }
  }
}
