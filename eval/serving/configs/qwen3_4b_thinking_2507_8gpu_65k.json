{
  "model": "Qwen/Qwen3-4B-Thinking-2507",
  "description": "Current LiveCodeBench v6 175-task serving setup for the thinking-only Qwen3 4B 2507 model.",
  "sources": [
    "https://huggingface.co/Qwen/Qwen3-4B-Thinking-2507",
    "https://qwen.readthedocs.io/en/latest/framework/function_call.html#vllm",
    "https://github.com/open-thoughts/OpenThoughts-Agent/blob/main/chat_templates/qwen3_thinking_acc.jinja2"
  ],
  "serve": {
    "gpus": [0, 1, 2, 3, 4, 5, 6, 7],
    "backend_ports": [8100, 8101, 8102, 8103, 8104, 8105, 8106, 8107],
    "backend_host": "0.0.0.0",
    "backend_base_url_host": "127.0.0.1",
    "proxy_host": "0.0.0.0",
    "proxy_port": 8000,
    "served_model_name": "Qwen/Qwen3-4B-Thinking-2507",
    "tensor_parallel_size": 1,
    "max_model_len": 65536,
    "gpu_memory_utilization": 0.9,
    "trust_remote_code": true,
    "chat_template": "eval/chat_templates/qwen3_thinking_acc.jinja2",
    "chat_template_content_format": "string",
    "vllm_args": [
      "--enable-auto-tool-choice",
      "--tool-call-parser",
      "hermes"
    ]
  },
  "generation": {
    "temperature": 0.6,
    "max_tokens": 60000,
    "request_timeout": 14400,
    "extra_body": {
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0,
      "presence_penalty": 0
    }
  },
  "benchmarks": {
    "livecodebench_v6_175": {
      "all_tasks": true,
      "n": 3,
      "generation_workers": 525,
      "evaluation_workers": 64,
      "timeout": 6
    }
  },
  "notes": [
    "No vLLM reasoning parser is used: deepseek_r1 dropped reasoning_content here; with no parser the model's own <think>...</think> stays in `content` and is retained across the agent chat history, matching training.",
    "The model card says this checkpoint supports only thinking mode; do not pass enable_thinking=false."
  ]
}
