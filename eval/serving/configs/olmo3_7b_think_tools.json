      "reference_run": "runs/olmo3-7b-think-swebench-multilingual-smoke-3-1gpu-required-20260605T0902Z"
    },
    "livecodebench_predictive_50": {
      "temperature": 0,
      "max_tokens": 4096,
      "api_base": "http://127.0.0.1:8000/v1",
      "successful_run": "runs/olmo3-7b-think-livecodebench-v6-8gpu-20260605T044048Z"
    }
  }
