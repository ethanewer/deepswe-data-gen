{
  "model": "sft/qwen3-sft/data/qwen3_vl_2b_text_checkpoint",
  "description": "Local text-only SWE-bench Multilingual serving setup for the Qwen3-VL-2B-Thinking starting checkpoint at 131k context.",
  "sources": [
    "https://huggingface.co/Qwen/Qwen3-VL-2B-Thinking",
    "https://github.com/open-thoughts/OpenThoughts-Agent/blob/main/chat_templates/qwen3_thinking_acc.jinja2"
  ],
  "serve": {
    "gpus": [0, 1, 2, 3, 4, 5, 6, 7],
    "backend_ports": [8100, 8101, 8102, 8103, 8104, 8105, 8106, 8107],
    "backend_host": "0.0.0.0",
    "backend_base_url_host": "127.0.0.1",
    "proxy_host": "0.0.0.0",
    "proxy_port": 8000,
    "served_model_name": "Qwen/Qwen3-VL-2B-Thinking",
    "tensor_parallel_size": 1,
    "max_model_len": 131072,
    "gpu_memory_utilization": 0.9,
    "trust_remote_code": true,
    "chat_template": "eval/chat_templates/qwen3_thinking_acc.jinja2",
    "chat_template_content_format": "string",
    "vllm_args": [
      "--reasoning-parser",
      "qwen3",
      "--enable-auto-tool-choice",
      "--tool-call-parser",
      "hermes"
    ]
  },
  "generation": {
    "temperature": 0.6,
    "max_tokens": 16384,
    "extra_body": {
      "top_p": 0.95,
      "top_k": 20,
      "min_p": 0,
      "presence_penalty": 0
    }
  },
  "benchmarks": {
    "swebench_multilingual_predictive_30": {
      "harness": "mini-swe-agent",
      "generation_workers": 8,
      "eval_workers": 4,
      "max_tokens": 16384,
      "temperature": 0.6
    }
  },
  "notes": [
    "This serves the same local starting checkpoint used by the Qwen3-VL-2B text SFT recipe.",
    "The SFT recipe uses the OpenThoughts Qwen3 thinking chat template; the same template is supplied to vLLM here.",
    "Qwen3 reasoning output parsing is enabled and Hermes is used as the generic Qwen-compatible tool-call parser, matching the Qwen3-VL-8B text eval setup."
  ]
}
